    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "report:merge": "npx mochawesome-merge cypress/reports/*.json > cypress/reports/merged-report.json",
    "report:generate": "npx marge cypress/reports/merged-report.json --reportDir cypress/reports/html --assetsDir cypress/reports/html/assets --reportFilename index.html",
    "test": "npm run cy:run && npm run report:merge && npm run report:generate"
  },
